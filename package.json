{
  "name": "@bz-reda/ETC-Admin-SDK",
  "version": "0.1.0",
  "description": "Official SDK for Espace-Tech Cloud — storage, auth, and database helpers",
  "author": "Espace-Tech <hello@espace-tech.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./storage": {
      "import": {
        "types": "./dist/storage/index.d.ts",
        "default": "./dist/storage/index.js"
      },
      "require": {
        "types": "./dist/storage/index.d.cts",
        "default": "./dist/storage/index.cjs"
      }
    },
    "./auth": {
      "import": {
        "types": "./dist/auth/index.d.ts",
        "default": "./dist/auth/index.js"
      },
      "require": {
        "types": "./dist/auth/index.d.cts",
        "default": "./dist/auth/index.cjs"
      }
    },
    "./database": {
      "import": {
        "types": "./dist/database/index.d.ts",
        "default": "./dist/database/index.js"
      },
      "require": {
        "types": "./dist/database/index.d.cts",
        "default": "./dist/database/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "espace-tech",
    "cloud",
    "storage",
    "s3",
    "auth",
    "database",
    "paas",
    "algeria",
    "africa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bz-reda/ETC-Admin-SDK"
  },
  "homepage": "https://cloud.espace-tech.com/docs",
  "engines": {
    "node": ">=18.0.0"
  }
}
